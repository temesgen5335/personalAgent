# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# All settings are read by src/jobagent/config.py via pydantic-settings.

# --- LLM (OpenRouter speaks the OpenAI API) ---
OPENROUTER_API_KEY=
JOBAGENT_LLM_MODEL=anthropic/claude-opus-4-8        # default reasoning model
JOBAGENT_EMBED_MODEL=openai/text-embedding-3-small  # for match prefilter

# --- Telegram: TWO distinct credentials, two distinct roles ---
# 1) Telethon (MTProto) — reads job-posting CHANNELS as your user account.
#    Get api_id / api_hash from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                                     # for first-run login
# 2) Bot API — the bot you TALK TO. Get token from @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=                                  # your numeric user id (lock the bot to you)

# --- Job source: aggregator for Indeed / LinkedIn / Glassdoor / JobRight ---
SERPAPI_KEY=                                        # serpapi.com Google Jobs engine
APIFY_TOKEN=                                        # optional secondary aggregator

# --- Store ---
JOBAGENT_DB_PATH=data/jobagent.db                   # sqlite for v1; swap to postgres URL later

# --- Email sending (Tier 1 apply) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
APPLY_FROM_EMAIL=
