# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# All settings are read by src/jobagent/config.py via pydantic-settings.

# --- LLM: multi-provider with automatic failover ---
# Set any subset of keys. The chain tries the primary first, then falls through to
# the next provider that has a key on any error / rate-limit / quota exhaustion.
LLM_PROVIDER=groq                  # primary: groq | gemini | openrouter | openai | anthropic
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Per-provider model overrides (free-friendly defaults shown):
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6
# Custom OpenAI-compatible endpoint (Ollama / vLLM / any local or hosted server):
CUSTOM_LLM_BASE_URL=                # e.g. http://localhost:11434/v1  (set LLM_PROVIDER=custom to prefer it)
CUSTOM_LLM_API_KEY=                 # blank is fine for local servers
CUSTOM_LLM_MODEL=                   # e.g. llama3.1

# --- Dashboard config UI (v2.1) ---
DASHBOARD_PASSWORD=                 # set to enable editing config from the dashboard (gates /config)
JOBAGENT_MASTER_KEY=                # Fernet key for the encrypted secret store: python scripts/genkey.py

# --- Telegram: TWO distinct credentials, two distinct roles ---
# 1) Telethon (MTProto) — reads job-posting CHANNELS as your user account.
#    Get api_id / api_hash from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=                                     # for first-run login
TELEGRAM_CHANNELS=                                  # comma-separated, e.g. @remote_jobs,@ai_jobs
TELEGRAM_SESSION=data/telegram                      # Telethon .session file path (gitignored)
TELEGRAM_FETCH_LIMIT=50                             # messages pulled per channel per run
# 2) Bot API — the bot you TALK TO. Get token from @BotFather.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                                   # where the bot DMs you; = your user id for a personal bot
TELEGRAM_OWNER_ID=                                  # optional alias/fallback for the owner gate

# --- ATS boards to watch (comma-separated company slugs) ---
GREENHOUSE_SLUGS=                                   # e.g. stripe,airbnb
LEVER_SLUGS=                                        # e.g. netflix
ASHBY_SLUGS=                                        # e.g. ramp

# --- Job source: aggregator for Indeed / LinkedIn / Glassdoor / JobRight ---
SERPAPI_KEY=                                        # serpapi.com Google Jobs engine
APIFY_TOKEN=                                        # optional secondary aggregator

# --- Store ---
JOBAGENT_DB_PATH=data/jobagent.db                   # sqlite for v1; swap to postgres URL later

# --- Email sending (Tier 1 apply) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
APPLY_FROM_EMAIL=
