---
import Layout from "../layouts/Layout.astro";
import { getMatches, storeExists, type MatchFilter } from "../lib/db";

const url = Astro.url;
const daysParam = url.searchParams.get("days") ?? "0";
const location = (url.searchParams.get("location") ?? "any") as MatchFilter["location"];
const q = url.searchParams.get("q") ?? "";

const filter: MatchFilter = {
  days: Number(daysParam) || 0,
  location,
  q: q.trim() || undefined,
  limit: 100,
};
const rows = storeExists() ? getMatches(filter) : [];

const dateOpts = [["0", "Any time"], ["1", "Today"], ["2", "2 days"], ["7", "Week"], ["30", "Month"]];
const locOpts = ["any", "remote", "hybrid"];
const fmtDate = (s: string | null) => (s ? new Date(s).toLocaleDateString() : "—");
---

<Layout title="Jobs">
  <h1>Jobs <span class="muted" style="font-size:14px">({rows.length})</span></h1>

  <form class="filters panel" method="get">
    <label>Date
      <select name="days">
        {dateOpts.map(([v, l]) => <option value={v} selected={v === daysParam}>{l}</option>)}
      </select>
    </label>
    <label>Location
      <select name="location">
        {locOpts.map((l) => <option value={l} selected={l === location}>{l}</option>)}
      </select>
    </label>
    <input type="search" name="q" placeholder="keywords e.g. frontend ai" value={q} />
    <button type="submit">Filter</button>
    <a href="/jobs" class="muted">reset</a>
  </form>

  <div class="panel">
    <table>
      <thead><tr><th>#</th><th>Score</th><th>Role</th><th>Company</th><th>Location</th><th>Source</th><th>Posted</th><th></th></tr></thead>
      <tbody>
        {rows.map((m, i) => (
          <tr>
            <td class="muted">{i + 1}</td>
            <td class="score">{Math.round(m.score * 100)}%</td>
            <td>{m.title}<br /><span class="muted" style="font-size:12px">{m.rationale}</span></td>
            <td>{m.company}</td>
            <td class="muted">{m.location || (m.is_remote ? "Remote" : "—")}</td>
            <td><span class="badge">{m.source}</span></td>
            <td class="muted">{fmtDate(m.posted_at)}</td>
            <td>{(m.apply_url || m.url) && <a href={m.apply_url || m.url} target="_blank">apply ↗</a>}</td>
          </tr>
        ))}
        {rows.length === 0 && <tr><td colspan="8" class="muted">No matches for these filters.</td></tr>}
      </tbody>
    </table>
  </div>
</Layout>
