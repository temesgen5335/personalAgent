---
import Layout from "../layouts/Layout.astro";
import { getApplications, apiBase, type AppRow } from "../lib/api";

let apps: AppRow[] = [];
let error: string | null = null;
try {
  apps = await getApplications(200);
} catch (e) {
  error = (e as Error).message;
}
const fmt = (s: string | null) => (s ? new Date(s).toLocaleString() : "—");
---

<Layout title="Applications">
  <h1>Applications <span class="muted" style="font-size:14px">({apps.length})</span></h1>

  {error && <div class="panel">⚠️ Can't reach the API at <code>{apiBase()}</code> — {error}</div>}

  <div class="panel">
    <table>
      <thead><tr><th>Role</th><th>Company</th><th>Method</th><th>Status</th><th>Created</th><th>Submitted</th><th></th></tr></thead>
      <tbody>
        {apps.map((a) => (
          <tr>
            <td>{a.title}</td>
            <td>{a.company}</td>
            <td class="muted">{a.apply_method}</td>
            <td><span class={`badge ${a.status}`}>{a.status}</span></td>
            <td class="muted">{fmt(a.created_at)}</td>
            <td class="muted">{fmt(a.submitted_at)}</td>
            <td>{(a.apply_url || a.url) && <a href={a.apply_url || a.url} target="_blank">link ↗</a>}</td>
          </tr>
        ))}
        {apps.length === 0 && !error && <tr><td colspan="7" class="muted">No applications yet — use /apply in the bot.</td></tr>}
      </tbody>
    </table>
  </div>
</Layout>
