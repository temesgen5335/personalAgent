---
import Layout from "../layouts/Layout.astro";
import { getStats, getMatches, getAnalytics, apiBase, type Stats, type MatchRow, type Analytics } from "../lib/api";

let stats: Stats | null = null;
let top: MatchRow[] = [];
let analytics: Analytics | null = null;
let error: string | null = null;
try {
  stats = await getStats();
  top = await getMatches({ limit: 10 });
  analytics = await getAnalytics();
} catch (e) {
  error = (e as Error).message;
}
const pctRate = (r: number) => `${Math.round(r * 100)}%`;
// Applications-per-day, oldest→newest, for the inline SVG chart.
const timeline = (analytics?.timeline ?? []).slice().reverse();
const tlMax = Math.max(1, ...timeline.map((t) => t.n));
const BW = 26, GAP = 6, H = 90;
const maxSource = stats ? Math.max(1, ...stats.bySource.map((s) => s.n)) : 1;
const fmt = (s: string | null) => (s ? new Date(s).toLocaleString() : "—");
---

<Layout title="Overview">
  <h1>Overview</h1>

  {error && (
    <div class="panel">
      ⚠️ Can't reach the API at <code>{apiBase()}</code> — {error}.<br />
      Start it: <code>PORT=8077 .venv/bin/python scripts/run_api.py</code> and set
      <code>JOBAGENT_API_URL</code> to match.
    </div>
  )}

  {stats && (
    <>
      <div class="cards">
        <div class="card"><div class="n">{stats.totalJobs.toLocaleString()}</div><div class="l">Jobs ingested</div></div>
        <div class="card"><div class="n">{stats.matches.toLocaleString()}</div><div class="l">Scored matches</div></div>
        <div class="card"><div class="n">{stats.strong.toLocaleString()}</div><div class="l">Strong (≥70%)</div></div>
        <div class="card"><div class="n">{stats.totalApps.toLocaleString()}</div><div class="l">Applications</div></div>
      </div>

      <div class="panel">
        <strong>Jobs by source</strong>
        <table>
          <tbody>
            {stats.bySource.map((s) => (
              <tr>
                <td style="width:120px">{s.source}</td>
                <td style="width:70px" class="muted">{s.n}</td>
                <td><div class="bar" style={`width:${(s.n / maxSource) * 100}%`}></div></td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="muted" style="margin:12px 0 0">Last ingest: {fmt(stats.lastIngest)}</p>
      </div>

      <div class="panel">
        <strong>Application funnel</strong>
        {!analytics || analytics.total === 0 ? (
          <p class="muted">No applications yet. Use <code>/apply</code> in the bot.</p>
        ) : (
          <>
            <p style="margin:10px 0">
              {Object.entries(analytics.by_status).map(([s, n]) => (
                <span class={`badge ${s}`} style="margin-right:8px">{s}: {n}</span>
              ))}
            </p>
            <div class="cards" style="margin:0">
              <div class="card"><div class="n">{analytics.submitted}</div><div class="l">Submitted</div></div>
              <div class="card"><div class="n">{pctRate(analytics.response_rate)}</div><div class="l">Response rate</div></div>
              <div class="card"><div class="n">{pctRate(analytics.interview_rate)}</div><div class="l">Interview rate</div></div>
              <div class="card"><div class="n">{pctRate(analytics.offer_rate)}</div><div class="l">Offer rate</div></div>
            </div>
            {analytics.by_source.length > 0 && (
              <p class="muted" style="margin-top:12px">
                By source: {analytics.by_source.map((s) => `${s.source} ${s.n}`).join(" · ")}
              </p>
            )}
            {timeline.length > 0 && (
              <div style="margin-top:16px">
                <span class="muted" style="font-size:13px">Applications per day</span>
                <svg width={timeline.length * (BW + GAP)} height={H + 20} style="display:block; margin-top:6px">
                  {timeline.map((t, i) => {
                    const h = Math.round((t.n / tlMax) * H);
                    return (
                      <g transform={`translate(${i * (BW + GAP)},0)`}>
                        <rect x="0" y={H - h} width={BW} height={h} rx="3" fill="var(--accent)"></rect>
                        <text x={BW / 2} y={H + 14} text-anchor="middle" fill="var(--muted)" font-size="9">{t.day.slice(5)}</text>
                      </g>
                    );
                  })}
                </svg>
              </div>
            )}
          </>
        )}
      </div>

      <div class="panel">
        <strong>Top matches</strong> · <a href="/jobs">see all →</a>
        <table style="margin-top:10px">
          <thead><tr><th>#</th><th>Score</th><th>Role</th><th>Company</th><th>Location</th></tr></thead>
          <tbody>
            {top.map((m, i) => (
              <tr>
                <td class="muted">{i + 1}</td>
                <td class="score">{Math.round(m.score * 100)}%</td>
                <td>{m.apply_url || m.url ? <a href={m.apply_url || m.url} target="_blank">{m.title}</a> : m.title}</td>
                <td>{m.company}</td>
                <td class="muted">{m.location || (m.is_remote ? "Remote" : "—")}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </>
  )}
</Layout>
