---
import Layout from "../../layouts/Layout.astro";
import { getJob, apiBase, type JobDetail } from "../../lib/api";

const { id } = Astro.params;
let job: JobDetail | null = null;
let error: string | null = null;
try {
  job = await getJob(id!);
} catch (e) {
  error = (e as Error).message;
}
const apiUrl = apiBase();
const link = job?.apply_url || job?.url || null;
const pct = job ? Math.round(job.score * 100) : 0;
---

<Layout title={job ? job.title : "Job"}>
  <p><a href="/jobs" class="muted">← back to jobs</a></p>
  {error && <div class="panel">⚠️ {error}</div>}

  {job && (
    <>
      <h1>{job.title}</h1>
      <div class="panel">
        <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap">
          <span class="score" style="font-size:22px">{pct}%</span>
          <span>{job.company}</span>
          <span class="muted">{job.location || (job.is_remote ? "Remote" : "—")}</span>
          <span class="badge">{job.source}</span>
          {link && <a href={link} target="_blank">apply ↗</a>}
        </div>
        {job.rationale && <p class="muted" style="margin:12px 0 0">{job.rationale}</p>}
      </div>

      <div class="panel">
        <div style="display:flex; justify-content:space-between; align-items:center">
          <strong>Fit check</strong>
          <button id="fit-btn" data-job={job.id}>Check fit</button>
        </div>
        <div id="fit-out" class="muted" style="margin-top:10px">Run a fit check against your CV.</div>
      </div>

      <div class="panel">
        <strong>Description</strong>
        <pre style="white-space:pre-wrap; font:inherit; margin:10px 0 0">{job.description || "—"}</pre>
      </div>
    </>
  )}

  <script define:vars={{ apiUrl }}>
    const btn = document.getElementById("fit-btn");
    btn?.addEventListener("click", async () => {
      const out = document.getElementById("fit-out");
      out.textContent = "Checking…";
      try {
        const r = await fetch(`${apiUrl}/fit`, {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ job_id: btn.dataset.job }),
        });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const f = await r.json();
        out.innerHTML = `
          <div style="font-size:20px" class="score">${Math.round(f.score * 100)}% fit
            <span class="badge">${f.source}</span></div>
          <p style="margin:8px 0 4px"><b>Matched:</b> ${(f.matched || []).join(", ") || "—"}</p>
          <p style="margin:4px 0"><b>Gaps:</b> ${(f.missing || []).join(", ") || "none"}</p>
          ${f.experience ? `<p class="muted" style="margin:4px 0">${f.experience}</p>` : ""}
          ${f.summary ? `<p style="margin:4px 0">${f.summary}</p>` : ""}`;
      } catch (e) {
        out.textContent = `Fit check failed: ${e.message}`;
      }
    });
  </script>
</Layout>
