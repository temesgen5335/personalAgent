---
import Layout from "../../layouts/Layout.astro";
import { getJob, apiBase, type JobDetail } from "../../lib/api";

const { id } = Astro.params;
let job: JobDetail | null = null;
let error: string | null = null;
try {
  job = await getJob(id!);
} catch (e) {
  error = (e as Error).message;
}
const apiUrl = apiBase();
const link = job?.apply_url || job?.url || null;
const pct = job ? Math.round(job.score * 100) : 0;
---

<Layout title={job ? job.title : "Job"}>
  <p><a href="/jobs" class="muted">← back to jobs</a></p>
  {error && <div class="panel">⚠️ {error}</div>}

  {job && (
    <>
      <h1>{job.title}</h1>
      <div class="panel">
        <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap">
          <span class="score" style="font-size:22px">{pct}%</span>
          <span>{job.company}</span>
          <span class="muted">{job.location || (job.is_remote ? "Remote" : "—")}</span>
          <span class="badge">{job.source}</span>
          {link && <a href={link} target="_blank">apply ↗</a>}
        </div>
        {job.rationale && <p class="muted" style="margin:12px 0 0">{job.rationale}</p>}
      </div>

      <div class="panel">
        <div style="display:flex; justify-content:space-between; align-items:center">
          <strong>Fit check</strong>
          <button id="fit-btn" data-job={job.id}>Check fit</button>
        </div>
        <div id="fit-out" class="muted" style="margin-top:10px">Run a fit check against your CV.</div>
      </div>

      <div class="panel">
        <strong>Description</strong>
        <pre style="white-space:pre-wrap; font:inherit; margin:10px 0 0">{job.description || "—"}</pre>
      </div>
    </>
  )}

  <style>
    .fit-head { display: flex; gap: 16px; align-items: center; margin-bottom: 14px; }
    .fit-ring { width: 64px; height: 64px; border-radius: 50%; flex: none;
      display: grid; place-items: center; font: 700 20px var(--mono); color: var(--accent-2);
      background: radial-gradient(circle at 50% 50%, var(--accent-dim), transparent 70%);
      border: 2px solid var(--accent); }
    .fit-ring span { font-size: 11px; }
    .fit-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
    .fit-sec h4 { margin: 0 0 8px; font-size: 12px; text-transform: uppercase; letter-spacing: .05em; color: var(--muted); font-weight: 600; }
    .chip { display: inline-block; margin: 0 4px 4px 0; padding: 3px 9px; border-radius: 8px; font-size: 12.5px;
      background: var(--panel-2); border: 1px solid var(--border-2); }
    .chip.ok { background: rgba(63,185,80,.12); color: #5ad16b; border-color: rgba(63,185,80,.28); }
    .chip.gap { background: rgba(227,160,8,.12); color: #e3a008; border-color: rgba(227,160,8,.28); }
  </style>

  <script define:vars={{ apiUrl }}>
    const btn = document.getElementById("fit-btn");
    btn?.addEventListener("click", async () => {
      const out = document.getElementById("fit-out");
      out.textContent = "Checking…";
      try {
        const r = await fetch(`${apiUrl}/fit`, {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ job_id: btn.dataset.job }),
        });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const f = await r.json();
        const chips = (arr, cls) => (arr || []).map((x) => `<span class="chip ${cls || ""}">${x}</span>`).join(" ") || "<span class='muted'>—</span>";
        const locOk = f.location_fit;
        out.innerHTML = `
          <div class="fit-head">
            <div class="fit-ring">${Math.round(f.score * 100)}<span>%</span></div>
            <div><div class="fit-src badge">${f.source} assessment</div>
              ${f.summary ? `<p style="margin:6px 0 0">${f.summary}</p>` : ""}</div>
          </div>
          <div class="fit-grid">
            <div class="fit-sec"><h4>🛠 Skills / keywords <span class="muted">(${Math.round((f.coverage||0)*100)}% coverage)</span></h4>${chips(f.matched, "ok")}</div>
            <div class="fit-sec"><h4>⚠️ Requirement gaps</h4>${chips(f.missing, "gap")}</div>
            <div class="fit-sec"><h4>📍 Location</h4><span class="chip ${locOk ? "ok" : "gap"}">${f.location_note || (locOk ? "fits" : "mismatch")}</span></div>
            <div class="fit-sec"><h4>🧭 Experience</h4><span class="muted">${f.experience || "—"}</span></div>
          </div>`;
      } catch (e) {
        out.textContent = `Fit check failed: ${e.message}`;
      }
    });
  </script>
</Layout>
